{
  "manifest_version": 3,
  "name": "Humbleman Site Key Manager",
  "version": "1.0.0",
  "description": "PGP-encrypted credential vault with multi-identity support",
  "icons": {
    "16": "icons/icon16.png",
    "32": "icons/icon32.png",
    "48": "icons/icon48.png",
    "128": "icons/icon128.png"
  },
  "action": {
    "default_icon": {
      "16": "icons/icon16.png",
      "32": "icons/icon32.png"
    },
    "default_title": "Humbleman Site Key Manager"
  },
  "sidebar_action": {
    "default_panel": "sidepanel/sidepanel.html",
    "default_title": "Humbleman Site Key Manager",
    "default_icon": {
      "16": "icons/icon16.png",
      "48": "icons/icon48.png"
    }
  },
  "browser_specific_settings": {
    "gecko": {
      "id": "sitekey@extension",
      "strict_min_version": "128.0"
    }
  },
  "background": {
    "scripts": ["background/service-worker.js"],
    "service_worker": "background/service-worker.js",
    "type": "module"
  },
  "content_scripts": [
    {
      "matches": ["http://*/*", "https://*/*"],
      "js": ["content/content-script.js"],
      "run_at": "document_idle"
    }
  ],
  "permissions": [
    "storage",
    "tabs",
    "alarms",
    "clipboardWrite",
    "downloads"
  ],
  "options_page": "options/options.html",
  "web_accessible_resources": [{
    "resources": ["mascot.svg"],
    "matches": ["<all_urls>"]
  }]
}
